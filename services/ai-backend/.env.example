# ============================================================
# Celestia Memoria - AI Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# For local development without external services, set USE_LOCAL_MODE=true

# --- Mode ---
USE_LOCAL_MODE=false          # Set to true for local dev (SQLite + Ollama, no API keys needed)
ENABLE_WATCHER=false          # Set to true to enable data/ directory file watcher

# --- Supabase (not required in local mode) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret

# --- OpenRouter (not required in local mode) ---
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=anthropic/claude-sonnet-4-5
OPENROUTER_ROUTER_MODEL=google/gemini-flash-1.5

# --- Pinecone (not required in local mode) ---
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=celestia-memoria
PINECONE_ENVIRONMENT=us-east-1-aws

# --- Cohere Reranking (not required in local mode) ---
COHERE_API_KEY=...
COHERE_RERANK_MODEL=rerank-english-v3.0
COHERE_RERANK_TOP_N=10

# --- Ollama (only used in local mode) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- LangSmith Tracing (optional) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=celestia-memoria

# --- Sentry (optional) ---
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- CORS ---
FRONTEND_URL=http://localhost:3000

# --- Server ---
PORT=8000
